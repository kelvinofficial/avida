+import React, { useState, useEffect, useCallback } from 'react';
+import {
+  View,
+  Text,
+  StyleSheet,
+  ScrollView,
+  TouchableOpacity,
+  ActivityIndicator,
+  RefreshControl,
+} from 'react-native';
+import { SafeAreaView } from 'react-native-safe-area-context';
+import { useRouter, useLocalSearchParams } from 'expo-router';
+import { Ionicons } from '@expo/vector-icons';
+import api from '../../src/utils/api';
+
+const COLORS = {
+  primary: '#16A34A',
+  text: '#1A1A1A',
+  textSecondary: '#6B7280',
+  surface: '#FFFFFF',
+  background: '#F5F5F5',
+  border: '#E5E7EB',
+  info: '#2563EB',
+  warning: '#D97706',
+  error: '#DC2626',
+  success: '#16A34A',
+};
+
+const STATUS_META: Record<string, { color: string; bg: string; icon: string; label: string }> = {
+  pending_payment: { color: '#D97706', bg: '#FEF3C7', icon: 'time-outline', label: 'Awaiting Payment' },
+  paid: { color: '#16A34A', bg: '#DCFCE7', icon: 'card-outline', label: 'Payment Confirmed' },
+  preparing: { color: '#7C3AED', bg: '#EDE9FE', icon: 'cube-outline', label: 'Preparing' },
+  shipped: { color: '#2563EB', bg: '#DBEAFE', icon: 'airplane-outline', label: 'Shipped' },
+  in_transit: { color: '#2563EB', bg: '#DBEAFE', icon: 'car-outline', label: 'In Transit' },
+  delivered: { color: '#16A34A', bg: '#DCFCE7', icon: 'checkmark-circle', label: 'Delivered' },
+  confirmed: { color: '#16A34A', bg: '#DCFCE7', icon: 'checkmark-done', label: 'Confirmed' },
+  completed: { color: '#16A34A', bg: '#DCFCE7', icon: 'checkmark-done-circle', label: 'Completed' },
+  disputed: { color: '#DC2626', bg: '#FEE2E2', icon: 'alert-circle-outline', label: 'Disputed' },
+  cancelled: { color: '#6B7280', bg: '#F3F4F6', icon: 'close-circle-outline', label: 'Cancelled' },
+};
+
+function formatDateTime(dateString: string | null) {
+  if (!dateString) return null;
+  const d = new Date(dateString);
+  return {
+    date: d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
+    time: d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }),
+    relative: getRelativeTime(d),
+  };
+}
+
+function getRelativeTime(date: Date) {
+  const diffMs = Date.now() - date.getTime();
+  const diffMins = Math.floor(diffMs / 60000);
+  const diffHours = Math.floor(diffMs / 3600000);
+  const diffDays = Math.floor(diffMs / 86400000);
+  if (diffMins < 1) return 'Just now';
+  if (diffMins < 60) return `${diffMins}m ago`;
+  if (diffHours < 24) return `${diffHours}h ago`;
+  if (diffDays < 7) return `${diffDays}d ago`;
+  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
+}
+
+export default function OrderTrackingScreen() {
+  const router = useRouter();
+  const { id } = useLocalSearchParams<{ id: string }>();
+  
+  const [loading, setLoading] = useState(true);
+  const [refreshing, setRefreshing] = useState(false);
+  const [tracking, setTracking] = useState<any>(null);
+  const [error, setError] = useState<string | null>(null);
+
+  const fetchTracking = useCallback(async () => {
+    try {
+      setError(null);
+      const response = await api.get(`/escrow/orders/${id}/tracking`);
+      setTracking(response.data);
+    } catch (err: any) {
+      setError(err.response?.data?.detail || 'Failed to load tracking data');
+    }
+    setLoading(false);
+    setRefreshing(false);
+  }, [id]);
+
+  useEffect(() => {
+    if (id) fetchTracking();
+  }, [id, fetchTracking]);
+
+  const onRefresh = () => {
+    setRefreshing(true);
+    fetchTracking();
+  };
+
+  if (loading) {
+    return (
+      <SafeAreaView style={styles.container}>
+        <View style={styles.loadingContainer}>
+          <ActivityIndicator size="large" color={COLORS.primary} />
+          <Text style={styles.loadingText}>Loading tracking...</Text>
+        </View>
+      </SafeAreaView>
+    );
+  }
+
+  if (error || !tracking) {
+    return (
+      <SafeAreaView style={styles.container}>
+        <View style={styles.header}>
+          <TouchableOpacity onPress={() => router.back()} style={styles.backBtn}>
+            <Ionicons name="arrow-back" size={24} color={COLORS.text} />
+          </TouchableOpacity>
+          <Text style={styles.headerTitle}>Order Tracking</Text>
+          <View style={{ width: 32 }} />
+        </View>
+        <View style={styles.errorContainer}>
+          <Ionicons name="alert-circle" size={48} color={COLORS.error} />
+          <Text style={styles.errorTitle}>Tracking Not Available</Text>
+          <Text style={styles.errorText}>{error || 'Could not load tracking information.'}</Text>
+          <TouchableOpacity style={styles.retryBtn} onPress={fetchTracking}>
+            <Text style={styles.retryBtnText}>Try Again</Text>
+          </TouchableOpacity>
+        </View>
+      </SafeAreaView>
+    );
+  }
+
+  const currentMeta = STATUS_META[tracking.status] || STATUS_META.pending_payment;
+
+  return (
+    <SafeAreaView style={styles.container}>
+      {/* Header */}
+      <View style={styles.header}>
+        <TouchableOpacity onPress={() => router.back()} style={styles.backBtn}>
+          <Ionicons name="arrow-back" size={24} color={COLORS.text} />
+        </TouchableOpacity>
+        <Text style={styles.headerTitle}>Order Tracking</Text>
+        <TouchableOpacity onPress={onRefresh} style={styles.backBtn}>
+          <Ionicons name="refresh" size={22} color={COLORS.textSecondary} />
+        </TouchableOpacity>
+      </View>
+
+      <ScrollView
+        style={styles.content}
+        refreshControl={<RefreshControl refreshing={refreshing} onRefresh={onRefresh} tintColor={COLORS.primary} />}
+        showsVerticalScrollIndicator={false}
+      >
+        {/* Status Card */}
+        <View style={styles.statusCard}>
+          <View style={styles.statusCardTop}>
+            <View style={styles.statusCardInfo}>
+              <Text style={styles.orderId}>#{tracking.order_id?.slice(-8)}</Text>
+              {tracking.listing_title && (
+                <Text style={styles.itemTitle} numberOfLines={1}>{tracking.listing_title}</Text>
+              )}
+            </View>
+            <View style={[styles.statusBadge, { backgroundColor: currentMeta.bg }]}>
+              <Ionicons name={currentMeta.icon as any} size={16} color={currentMeta.color} />
+              <Text style={[styles.statusBadgeText, { color: currentMeta.color }]}>
+                {currentMeta.label}
+              </Text>
+            </View>
+          </View>
+
+          {/* Meta tags */}
+          <View style={styles.metaRow}>
+            {tracking.delivery_method && (
+              <View style={styles.metaTag}>
+                <Ionicons 
+                  name={tracking.delivery_method === 'door_delivery' ? 'car-outline' : 'location-outline'} 
+                  size={14} color={COLORS.textSecondary} 
+                />
+                <Text style={styles.metaTagText}>
+                  {tracking.delivery_method === 'door_delivery' ? 'Door Delivery' : 'Pickup'}
+                </Text>
+              </View>
+            )}
+            {tracking.tracking_number && (
+              <View style={styles.metaTag}>
+                <Ionicons name="locate-outline" size={14} color={COLORS.textSecondary} />
+                <Text style={styles.metaTagText}>{tracking.tracking_number}</Text>
+              </View>
+            )}
+            {tracking.escrow_status && (
+              <View style={[styles.metaTag, { backgroundColor: '#DBEAFE' }]}>
+                <Ionicons name="shield-checkmark" size={14} color={COLORS.info} />
+                <Text style={[styles.metaTagText, { color: COLORS.info }]}>
+                  Escrow: {tracking.escrow_status.replace(/_/g, ' ')}
+                </Text>
+              </View>
+            )}
+          </View>
+        </View>
+
+        {/* Timeline */}
+        <View style={styles.timelineCard}>
+          <Text style={styles.timelineTitle}>Order Timeline</Text>
+          
+          {tracking.timeline?.map((step: any, idx: number) => {
+            const meta = STATUS_META[step.status] || STATUS_META.pending_payment;
+            const ts = formatDateTime(step.timestamp);
+            const isLast = idx === tracking.timeline.length - 1;
+            
+            return (
+              <View key={step.status} style={styles.timelineStep}>
+                {/* Connector line */}
+                {!isLast && (
+                  <View style={[
+                    styles.timelineConnector,
+                    step.completed ? styles.connectorCompleted : styles.connectorPending
+                  ]} />
+                )}
+                
+                {/* Icon */}
+                <View style={[
+                  styles.timelineIcon,
+                  { 
+                    backgroundColor: step.completed ? meta.color : '#E5E7EB',
+                  },
+                  step.is_current && { 
+                    shadowColor: meta.color, shadowOpacity: 0.4, shadowRadius: 8, elevation: 4 
+                  },
+                ]}>
+                  <Ionicons 
+                    name={meta.icon as any} 
+                    size={20} 
+                    color={step.completed ? '#fff' : '#9CA3AF'} 
+                  />
+                </View>
+                
+                {/* Content */}
+                <View style={styles.timelineContent}>
+                  <View style={styles.timelineContentHeader}>
+                    <Text style={[
