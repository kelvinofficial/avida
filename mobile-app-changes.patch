+    description: 'When a buyer places and pays for a new order',
+    icon: 'bag-add-outline',
+    role: 'seller',
+  },
+  {
+    key: 'order_shipped' as keyof PushPreferences,
+    title: 'Order Shipped',
+    description: 'When the seller ships your order with tracking info',
+    icon: 'airplane-outline',
+    role: 'buyer',
