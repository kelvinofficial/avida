+    title: 'Dispute Updates',
+    description: 'Updates on dispute resolution and outcomes',
+    icon: 'alert-circle-outline',
+    role: 'both',
+  },
+];
+
+export default function NotificationPreferencesScreen() {
+  const router = useRouter();
+  const { isAuthenticated } = useAuthStore();
+  const [prefs, setPrefs] = useState<PushPreferences>(DEFAULT_PREFS);
+  const [loading, setLoading] = useState(true);
+  const [saving, setSaving] = useState(false);
+
+  const fetchPreferences = useCallback(async () => {
+    try {
+      setLoading(true);
+      const response = await api.get('/v1/notifications/push-preferences');
+      const data = response.data;
+      setPrefs({
+        payment_confirmed: data.payment_confirmed ?? true,
+        new_order: data.new_order ?? true,
+        order_shipped: data.order_shipped ?? true,
+        delivery_confirmed: data.delivery_confirmed ?? true,
