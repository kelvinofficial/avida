+  }, []);
+
+  useEffect(() => {
+    if (isAuthenticated) {
+      fetchPreferences();
+    }
+  }, [isAuthenticated]);
+
+  const togglePreference = async (key: keyof PushPreferences) => {
+    const updated = { ...prefs, [key]: !prefs[key] };
